{
  "name": "@pipit-ui/hooks",
  "version": "0.0.2",
  "description": "Hooks for pipit-ui",
  "type": "module",
  "main": "dist/lib/index.js",
  "module": "dist/es/index.mjs",
  "types": "dist/es/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/es/index.d.ts",
      "import": "./dist/es/index.mjs",
      "require": "./dist/lib/index.js"
    },
    "./use-namespace": {
      "types": "./dist/es/use-namespace.d.ts",
      "import": "./dist/es/use-namespace.mjs",
      "require": "./dist/lib/use-namespace.js"
    },
    "./es/*": "./dist/es/*",
    "./lib/*": "./dist/lib/*"
  },
  "files": [
    "dist"
  ],
  "dependencies": {
    "@pipit-ui/constants": "workspace:*"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  }
}
