{
  "name": "pipit-ui",
  "version": "0.0.3",
  "description": "A Vue 3 based component library",
  "type": "module",
  "main": "dist/pipit-ui.js",
  "module": "dist/pipit-ui.mjs",
  "types": "dist/es/es-entry.d.ts",
  "sideEffects": [
    "dist/index.css",
    "dist/theme-chalk/**/*.scss",
    "**/*.scss"
  ],
  "exports": {
    ".": {
      "types": "./dist/es/es-entry.d.ts",
      "import": "./dist/pipit-ui.mjs",
      "require": "./dist/pipit-ui.js"
    },
    "./es": {
      "types": "./dist/es/es-entry.d.ts",
      "import": "./dist/es/es-entry.mjs"
    },
    "./lib": {
      "types": "./dist/lib/es-entry.d.ts",
      "require": "./dist/lib/es-entry.js"
    },
    "./es/*": "./dist/es/*",
    "./lib/*": "./dist/lib/*",
    "./dist/*.css": "./dist/*.css",
    "./dist/theme-chalk/*": "./dist/theme-chalk/*",
    "./*": "./*"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "vite build --watch",
    "build": "pnpm run build:full && pnpm run build:es && pnpm run build:theme && pnpm run build:types",
    "build:full": "vite build",
    "build:es": "node scripts/build-modules.mjs",
    "build:theme": "node scripts/copy-theme.mjs",
    "build:types": "tsc --project tsconfig.json --emitDeclarationOnly && tsc --project tsconfig.types.lib.json --emitDeclarationOnly"
  },
  "peerDependencies": {
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@pipit-ui/components": "workspace:*",
    "@pipit-ui/constants": "workspace:*",
    "@pipit-ui/directives": "workspace:*",
    "@pipit-ui/hooks": "workspace:*",
    "@pipit-ui/locale": "workspace:*",
    "@pipit-ui/theme-chalk": "workspace:*",
    "@pipit-ui/utils": "workspace:*"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^5.2.3",
    "@vitejs/plugin-vue-jsx": "^4.1.2",
    "typescript": "~5.7.0",
    "vite": "^6.3.1",
    "vue": "^3.5.13"
  }
}
